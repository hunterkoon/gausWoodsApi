    format "    spinner spDesp \"Aplicar: \" range:[0,50,%] type:#float fieldWidth:80 align:#left\n" despEst to:ss
    format "    label lbDi \"  (base 3 pct + complexidade por nr de pecas e espessuras)\" align:#left\n" to:ss
    format "  )\n" to:ss

    -- ── Fita de Borda: busca API por acabamento ──────────────
    format "  group \"Fita de Borda\" (\n" to:ss
    format "    label lbFl \"Fita total: % m\" align:#left\n" fitaArred to:ss
    format "    label lbSelFita1 \"(nenhuma fita selecionada)\" align:#left offset:[10,0]\n" to:ss
    if G_ApiOnline then
        format "    button btnBuscaFita1 \"Buscar Fita na API\" width:160 height:22 align:#left offset:[10,0] across:2\n" to:ss
    else
        format "    button btnBuscaFita1 \"Buscar Fita na API\" width:160 height:22 align:#left offset:[10,0] across:2 enabled:false\n" to:ss
    format "    spinner spFita \"R$/m (manual):\" range:[0,9999,0.0] type:#float fieldWidth:100\n" to:ss
    format "    label lbRl \"Tamanho do rolo:\" across:2 align:#left width:220\n" to:ss
    format "    spinner spRolo \"m\" range:[1,9999,50] type:#integer fieldWidth:100\n" to:ss
    format "  )\n" to:ss

    -- ── Outros custos ────────────────────────────────────────
    format "  group \"Outros Custos\" (\n" to:ss
    format "    label lbFr \"Ferragem:\" across:2 align:#left width:220\n" to:ss
    format "    spinner spFerr \"R$\" range:[0,999999,0.0] type:#float fieldWidth:100\n" to:ss
    format "    label lbCo \"Cola:\" across:2 align:#left width:220\n" to:ss
    format "    spinner spCola \"R$\" range:[0,99999,0.0] type:#float fieldWidth:100\n" to:ss
    format "    label lbMo \"Mao de Obra:\" across:2 align:#left width:220\n" to:ss
    format "    spinner spMO \"R$\" range:[0,999999,0.0] type:#float fieldWidth:100\n" to:ss
    format "    label lbFre \"Transporte / Frete:\" across:2 align:#left width:220\n" to:ss
    format "    spinner spFrete \"R$\" range:[0,999999,0.0] type:#float fieldWidth:100\n" to:ss
    format "  )\n" to:ss

    -- ── Resultado calculado ──────────────────────────────────
    format "  group \"Resultado\" (\n" to:ss
    format "    label lbRch \"Chapas: R$ --\" align:#left\n" to:ss
    format "    label lbRft \"Fita: R$ -- (-- rolos)\" align:#left\n" to:ss
    format "    label lbRou \"Outros (ferragem+cola+MO): R$ --\" align:#left\n" to:ss
    format "    label lbRfr \"Transporte/Frete: R$ --\" align:#left\n" to:ss
    format "    label lbTot \"TOTAL ESTIMADO: R$ --\" align:#left height:20\n" to:ss
    format "  )\n" to:ss

    -- ── Botões ───────────────────────────────────────────────
    format "  button btnCriarCot \"Criar Cotação e Gerar Planilha\" width:380 height:36 align:#left offset:[0,8]\n" to:ss
    format "  button btnClose    \"Fechar\" width:140 height:36 align:#right offset:[0,-36]\n" to:ss

    -- ── fn atualizarLabels: lê G_ApiChapaPrecos e atualiza labels ──
    format "  fn atualizarLabels = (\n" to:ss
    for i = 1 to G_ChapasGrupos.count do
    (
        local espMm = G_ChapasGrupos[i][1]
        format "    for entry in G_ApiChapaPrecos do (\n" to:ss
        format "      if abs(entry[1] - %) < 0.5 do (\n" espMm to:ss
        format "        lbSelChapa%.text = entry[3] + \" — R$ \" + (entry[2] as string)\n" i to:ss
        format "        spP%.value = entry[2]\n" i to:ss
        format "      )\n" to:ss
        format "    )\n" to:ss
    )
    -- Fita labels
    format "    if G_ApiFitaPrecos.count > 0 do (\n" to:ss
    format "      local ft = G_ApiFitaPrecos[1]\n" to:ss
    format "      lbSelFita1.text = ft[3] + \" — R$/m \" + (ft[2] as string)\n" to:ss
    format "      spFita.value = ft[2]\n" to:ss
    format "      spRolo.value = ft[4] as integer\n" to:ss
    format "    )\n" to:ss
    format "  )\n" to:ss

    -- ── fn recalcular (sem closure: qtd e fita embutidos) ────
    format "  fn recalcular = (\n" to:ss
    format "    atualizarLabels()\n" to:ss
    -- custo por espessura com desperdício
    for i = 1 to G_ChapasGrupos.count do
        format "    local cc% = % * spP%.value * (1.0 + spDesp.value/100.0)\n" i G_ChapasGrupos[i][2] i to:ss
    format "    local ccTot = " to:ss
    for i = 1 to G_ChapasGrupos.count do ( if i>1 do format " + " to:ss; format "cc%" i to:ss )
    format "\n" to:ss
    format "    local fm  = %\n" fitaMetros to:ss
    format "    local cf  = fm * spFita.value\n" to:ss
    format "    local nr  = (ceil (fm / (if spRolo.value > 0 then spRolo.value else 1))) as integer\n" to:ss
    format "    local out = spFerr.value + spCola.value + spMO.value\n" to:ss
    format "    local fre = spFrete.value\n" to:ss
    format "    local tot = ccTot + cf + out + fre\n" to:ss
    -- Inline: sem fn aninhada para evitar erro de closure
    format "    lbRch.text = \"Chapas (c/ \" + (spDesp.value as string) + \" pct desp.): R$ \" + (((floor(ccTot*100+0.5))/100.0) as string)\n" to:ss
    format "    lbRft.text = \"Fita: R$ \" + (((floor(cf*100+0.5))/100.0) as string) + \" (\" + (nr as string) + \" rolos de \" + (spRolo.value as string) + \"m)\"\n" to:ss
    format "    lbRou.text = \"Outros (ferragem+cola+MO): R$ \" + (((floor(out*100+0.5))/100.0) as string)\n" to:ss
    format "    lbRfr.text = \"Transporte/Frete: R$ \" + (((floor(fre*100+0.5))/100.0) as string)\n" to:ss
    format "    lbTot.text = \"TOTAL ESTIMADO: R$ \" + (((floor(tot*100+0.5))/100.0) as string)\n" to:ss
    format "  )\n" to:ss

    -- ── Eventos: Busca de Chapas ─────────────────────────────
    -- Nota: createDialog não é bloqueante, então recalcular é chamado
    -- pelo botão Calcular ou via atualizarLabels no open do dialog.
    -- Aqui apenas abrimos o modal de busca.
    for i = 1 to G_ChapasGrupos.count do
    (
        local espMm = G_ChapasGrupos[i][1]
        format "  on btnBuscaChapa% pressed do ( ::abrirBuscaChapaAPI % % )\n" i i espMm to:ss
    )

    -- ── Evento: Busca de Fita ────────────────────────────────
    format "  on btnBuscaFita1 pressed do (\n" to:ss
    format "    local acab = \"Geral\"\n" to:ss
    -- Tenta pegar acabamento da primeira chapa selecionada via API
    format "    if G_ApiChapaPrecos.count > 0 do acab = G_ApiChapaPrecos[1][4]\n" to:ss
    format "    ::abrirBuscaFitaAPI 1 acab\n" to:ss
    format "  )\n" to:ss

    -- ── Eventos spinner ──────────────────────────────────────
    -- Spinners recalculam ao vivo
    for i = 1 to G_ChapasGrupos.count do
        format "  on spP% changed v do recalcular()\n" i to:ss
    format "  on spDesp  changed v do recalcular()\n" to:ss
    format "  on spFita  changed v do recalcular()\n" to:ss
    format "  on spRolo  changed v do recalcular()\n" to:ss
    format "  on spFerr  changed v do recalcular()\n" to:ss
    format "  on spCola  changed v do recalcular()\n" to:ss
    format "  on spMO    changed v do recalcular()\n" to:ss
    format "  on spFrete changed v do recalcular()\n" to:ss
    format "  on btnClose pressed do destroyDialog rlCusto\n" to:ss

    -- ── Criar Cotação: recalcula + POST API + gera Excel ────
    format "  on btnCriarCot pressed do (\n" to:ss
    format "    recalcular()\n" to:ss

    -- Monta array chapas para a API
    format "    local chapasArr = #()\n" to:ss
    for i = 1 to G_ChapasGrupos.count do
    (
        local espMm = G_ChapasGrupos[i][1]
        local qtd   = G_ChapasGrupos[i][2]
        -- Tenta achar produto selecionado via API; senão usa "Manual"
        format "    local nomeProd% = \"Manual\"\n" i to:ss
        format "    for en in G_ApiChapaPrecos do if abs(en[1] - %) < 0.5 do nomeProd% = en[3]\n" espMm i to:ss
        format "    local sub% = % * spP%.value * (1.0 + spDesp.value / 100.0)\n" i qtd i to:ss
        format "    append chapasArr #(%, nomeProd%, %, spP%.value, sub%)\n" espMm i qtd i i to:ss
    )

    -- Monta array fitas
    format "    local fitasArr = #()\n" to:ss
    format "    local nomeFita = \"Manual\"\n" to:ss
    format "    if G_ApiFitaPrecos.count > 0 do nomeFita = G_ApiFitaPrecos[1][3]\n" to:ss
    format "    local subFita = % * spFita.value\n" fitaMetros to:ss
    format "    append fitasArr #(nomeFita, %, spFita.value, subFita)\n" fitaMetros to:ss

    -- Outros custos
    format "    local outrosArr = #(spFerr.value, spCola.value, spMO.value, spFrete.value)\n" to:ss
    format "    local totalOut  = spFerr.value + spCola.value + spMO.value + spFrete.value\n" to:ss

    -- Totais
    format "    local ccTotFinal = " to:ss
    for i = 1 to G_ChapasGrupos.count do ( if i>1 do format " + " to:ss; format "(% * spP%.value * (1.0 + spDesp.value / 100.0))" G_ChapasGrupos[i][2] i to:ss )
    format "\n" to:ss
    format "    local cfFinal = % * spFita.value\n" fitaMetros to:ss
    format "    local totFinal = ccTotFinal + cfFinal + totalOut\n" to:ss

    -- POST API (só se online)
    format "    local cotId = 0\n" to:ss
    format "    if G_ApiOnline then (\n" to:ss
    format "      local res = ::apiCriarCotacao chapasArr fitasArr outrosArr spDesp.value % ccTotFinal cfFinal totalOut totFinal\n" aprovArred to:ss
    format "      if res[1] then (\n" to:ss
    format "        cotId = res[2]\n" to:ss
    format "        messageBox res[3] title:\"Cotacao Criada\"\n" to:ss
    format "      ) else (\n" to:ss
    format "        messageBox (\"Aviso API: \" + res[3] + \"\\nPlanilha sera gerada sem registro no banco.\") title:\"Aviso\"\n" to:ss
    format "      )\n" to:ss
    format "    )\n" to:ss

    -- Gera Excel com cotacao
    format "    local precos = #(" to:ss
    for i = 1 to G_ChapasGrupos.count do ( if i>1 do format "," to:ss; format "spP%.value" i to:ss )
    format ")\n" to:ss
    format "    ::gerarPlanilhaExcel precos spDesp.value spFita.value spFerr.value spCola.value spMO.value spFrete.value cotacaoId:cotId\n" to:ss
    format "  )\n" to:ss

    format "  on rlCusto open do recalcular()\n" to:ss
    format ")\n" to:ss
    format "createDialog rlCusto style:#(#style_titlebar, #style_border, #style_sysmenu)\n" to:ss

    execute (ss as string)
)

