-- UI UNIFICADA: Custo + Planilha em uma única janela
-- Integrada com API Banco de Dados para busca de precos
-- ============================================================
fn abrirUICustoCompleto nChapas aproveitamento fitaMetros =
(
    local fitaArred = (floor (fitaMetros * 10 + 0.5)) / 10.0
    local aprovArred= (floor (aproveitamento * 10 + 0.5)) / 10.0
    local nEsp      = G_ChapasGrupos.count
    local nPecas    = G_PiecesData.count
    local despEst   = calcEstimativaDesperdicio nPecas nEsp aproveitamento

    -- Limpa selecoes anteriores da API
    G_ApiChapaPrecos = #()
    G_ApiFitaPrecos  = #()

    -- Coleta acabamentos unicos das chapas selecionadas via API (preenchido depois)
    -- Por agora, inicializa com 1 linha de fita generica
    local acabamentos = #("Geral")

    local ss = stringStream ""

    format "rollout rlCusto \"Planejamento de Custo e Planilha\" width:560\n(\n" to:ss

    -- ── Status API ───────────────────────────────────────────
    if G_ApiOnline then
        format "  label lbApi \"API Banco de Dados: Conectada\" align:#right\n" to:ss
    else
        format "  label lbApi \"API Banco de Dados: Offline (precos manuais)\" align:#right\n" to:ss

