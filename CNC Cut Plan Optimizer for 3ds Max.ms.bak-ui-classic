            local gap    = spG.value / 25.4
            local borda  = spB.value / 25.4
            local sufixo = "_MED"
            local expDWG = chkDWG.checked
            local alignMode = ddAlign.selection
            local groupMode = ddGroup.selection

            if spW.value<=0 or spD.value<=0 then ( messageBox "Defina dimensoes validas." title:"Aviso"; return undefined )
            destroyDialog rlConfig
            processarFase1 binW binD gap borda sufixo expDWG alignMode groupMode
        )
    )
    addRollout rlConfig dlg
)

-- ============================================================
-- FEATURE 1: Verificação de API na inicialização
-- ============================================================
fn verificarEIniciar =
(
    format "Verificando API Banco de Dados...\n"
    local online = apiHealthCheck()

    if online then
    (
        format "API Banco de Dados: ONLINE\n"
        abrirUIPrincipal()
    )
    else
    (
        -- Modal perguntando se deseja iniciar a API
        local ss = stringStream ""
        format "rollout rlApiCheck \"API Banco de Dados\" width:380 (\n" to:ss
        format "  label lbMsg1 \"API Banco de Dados nao encontrada em localhost:8080\" align:#center offset:[0,10]\n" to:ss
        format "  label lbMsg2 \"Deseja inicia-la automaticamente?\" align:#center offset:[0,4]\n" to:ss
        format "  label lbMsg3 \"(necessario PostgreSQL rodando)\" align:#center offset:[0,2]\n" to:ss
        format "  button btnStart \"Iniciar API\" width:160 height:32 align:#left offset:[20,16]\n" to:ss
        format "  button btnSkip  \"Continuar sem API\" width:160 height:32 align:#right offset:[-20,-32]\n" to:ss
        format "  on btnStart pressed do (\n" to:ss
        format "    lbMsg2.text = \"Iniciando API... aguarde...\"\n" to:ss
        format "    btnStart.enabled = false\n" to:ss
        format "    btnSkip.enabled  = false\n" to:ss
        format "    local ok = ::apiStartServer()\n" to:ss
        format "    if ok then (\n" to:ss
        format "      messageBox \"API iniciada com sucesso!\" title:\"API OK\"\n" to:ss
        format "      destroyDialog rlApiCheck\n" to:ss
        format "      ::abrirUIPrincipal()\n" to:ss
        format "    ) else (\n" to:ss
        format "      lbMsg2.text = \"Falha ao iniciar. Verifique PostgreSQL.\"\n" to:ss
        format "      btnStart.enabled = true\n" to:ss
        format "      btnSkip.enabled  = true\n" to:ss
        format "    )\n" to:ss
        format "  )\n" to:ss
        format "  on btnSkip pressed do (\n" to:ss
        format "    destroyDialog rlApiCheck\n" to:ss
        format "    ::abrirUIPrincipal()\n" to:ss
        format "  )\n" to:ss
        format ")\n" to:ss
        format "createDialog rlApiCheck style:#(#style_titlebar, #style_border, #style_sysmenu)\n" to:ss
        execute (ss as string)
    )
)

verificarEIniciar()
